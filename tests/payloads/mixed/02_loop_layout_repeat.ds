VAR $INDEX = 0
GUI r
DELAY 350
STRING notepad
ENTER
DELAY 500
DEFAULT_STRING_DELAY 12
WHILE ($INDEX < 3)
STRING Loop value: 
STRINGLN $INDEX
$INDEX = ($INDEX + 1)
END_WHILE
STRINGLN Layout symbols: ! @ # $ % / ? + - _
STRINGLN Classic REPEAT follows
STRINGLN repeated line
REPEAT 2
MOUSE_SCROLL 1
MOUSE_SCROLL -1

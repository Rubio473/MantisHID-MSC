DEFINE $TITLE = "Mantis mixed regression"
VAR $A = 7
VAR $B = 5
VAR $SUM = ($A + $B)
FUNCTION HEADER()
STRINGLN $TITLE
RETURN
END_FUNCTION
FUNCTION CHECK_SUM()
IF (($SUM == 12) OR ($A == 0))
STRINGLN Arithmetic and OR passed
RETURN
END_IF
STRINGLN Arithmetic failed
RETURN
END_FUNCTION
GUI r
DELAY 350
STRING notepad
ENTER
DELAY 500
HEADER()
CHECK_SUM()
STRING Sum value: 
STRINGLN $SUM
DEFAULT_STRING_DELAY 8
STRINGLN Keyboard, mouse and media regression
MOUSE_MOVE -10 6
MOUSE_MOVE 10 -6
RIGHTCLICK
MEDIA MUTE
DELAY 120
MEDIA MUTE

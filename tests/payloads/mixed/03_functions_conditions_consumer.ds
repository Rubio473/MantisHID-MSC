DEFINE $MODE = 2
VAR $RESULT = 0
FUNCTION CALCULATE()
$RESULT = (($MODE * 5) + 1)
RETURN
END_FUNCTION
FUNCTION WRITE_RESULT()
STRING Result: 
STRINGLN $RESULT
RETURN
END_FUNCTION
GUI r
DELAY 350
STRING notepad
ENTER
DELAY 500
CALCULATE()
IF (($RESULT >= 11) AND NOT ($MODE == 3))
STRINGLN IF and logical operators passed
ELSE_IF ($RESULT == 10)
STRINGLN ELSE_IF branch
ELSE
STRINGLN ELSE branch
END_IF
WRITE_RESULT()
MEDIA VOLUME_UP
DELAY 120
MEDIA VOLUME_DOWN

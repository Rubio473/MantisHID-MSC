DEFINE $OPEN_WAIT = 500
VAR $READY = 1
FUNCTION OPEN_EDITOR()
GUI r
DELAY 350
STRING notepad
ENTER
DELAY $OPEN_WAIT
RETURN
END_FUNCTION
OPEN_EDITOR()
IF ($READY == 1)
STRINGLN Mantis DuckyScript 3 Core ready
ELSE
STRINGLN Core condition failed
END_IF
MOUSE_MOVE 18 0
MOUSE_MOVE -18 0
MEDIA MUTE
DELAY 120
MEDIA MUTE
